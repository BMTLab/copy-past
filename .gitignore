# ─── Project-local: bats artifacts ───────────────────────────────────────
# bats writes per-run temp dirs under $BATS_TMPDIR by default,
# but on CI / older systems they may end up under tests/.
.bats-tmp/
tests/.tmp/
tests/.bats/
tests/**/tmp/
*.bats.log

# ─── Project-local: shellcheck / shfmt caches ────────────────────────────
.shellcheckcache/

# ─── Generic temp / cache / build artifacts ──────────────────────────────
tmp/
temp/
cache/
.cache/
*.tmp
*.bak
*.old
*.log

# Tool outputs (kept here in case future tooling lands)
dist/
build/
out/
coverage/
reports/
node_modules/

# ─── Python (used by some sibling tools / CI helpers) ────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
.env/
.tox/
.mypy_cache/
.pytest_cache/
.ruff_cache/

# ─── Secrets ─────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.secret
*.key
*.pem
*.pfx
*.p12
id_rsa
id_ed25519
*.gpg

# ─── Local-only configuration overrides ──────────────────────────────────
# Anything ending in .local / .local.sh is treated as developer-private.
*.local
*.local.sh
local.mk
