# .editorconfig

root = true

[*]
charset                  = utf-8
end_of_line              = lf
insert_final_newline     = true
trim_trailing_whitespace = true
indent_style             = space
indent_size              = 2

[*.{sh,bash,bats}]
indent_style = space
indent_size  = 2

[{Makefile,*.mk,GNUmakefile,makefile}]
indent_style = tab
indent_size  = 4

[*.{yml,yaml}]
indent_style = space
indent_size  = 2

[*.json]
indent_style = space
indent_size  = 2

[*.md]
trim_trailing_whitespace = false

[*.{patch,diff}]
trim_trailing_whitespace = false
insert_final_newline     = false
